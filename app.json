{
  "expo": {
    "name": "Ours",
    "slug": "ours",
    "version": "1.0.0",
    "scheme": "ours",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#FAF6F0",
    "splash": {
      "backgroundColor": "#FAF6F0",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "name": "Ours",
      "shortName": "Ours",
      "display": "standalone",
      "startUrl": "/",
      "scope": "/",
      "orientation": "portrait",
      "backgroundColor": "#F4ECDD",
      "themeColor": "#F4ECDD"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Ours uses your photo library so you can add pictures to your shared memories."
        }
      ],
      "expo-asset"
    ]
  }
}
